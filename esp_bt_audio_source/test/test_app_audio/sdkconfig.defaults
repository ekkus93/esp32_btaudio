# Enable SPIRAM (PSRAM) for test runs so PSRAM allocations are exercised.
CONFIG_SPIRAM=n
# Enable mock hooks so test-only helpers (beep fallback, tag counters, etc.) are compiled for device tests.
CONFIG_BT_MOCK_TESTING=y
# Choose a reasonable default speed/mode — keep minimal to avoid platform-specific issues.
# These can be adjusted per-board if needed.
#CONFIG_SPIRAM_SPEED_80M=y
#CONFIG_SPIRAM_MODE_OCT=y
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192
CONFIG_UNITY_FREERTOS_STACK_SIZE=8192
CONFIG_FREERTOS_WATCHPOINT_END_OF_STACK=y
CONFIG_UNITY_ENABLE_FLOAT=y
CONFIG_UNITY_ENABLE_DOUBLE=y
CONFIG_UNITY_ENABLE_IDF_TEST_RUNNER=y
CONFIG_ESP_TASK_WDT_TIMEOUT_S=10

## Enable custom partition table so the test app uses the repository partitions.csv (needed for SPIFFS)
## Disable single-app partition table and enable custom partition table
# (Kconfig choice: only one partition table option may be selected)
# Disable single-app partition table
# CONFIG_PARTITION_TABLE_SINGLE_APP is not set
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="../../partitions.csv"
