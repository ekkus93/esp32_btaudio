menu "A2DP Example Configuration"
    config EXAMPLE_SSP_ENABLED
        bool "Secure Simple Pairing"
        depends on BT_CLASSIC_ENABLED
        default y
        help
            This enables the Secure Simple Pairing. If disable this option,
            Bluedroid will only support Legacy Pairing

    config EXAMPLE_PEER_DEVICE_NAME
        string "Target Device Name"
        default "ESP_SPEAKER"
        help
            Use this option to set target device name to connect.

    config AUDIO_USE_SYNTH_SOURCE
        bool "Use synthetic audio source (no I2S)"
        default n
        help
            When enabled the audio processor will generate a synthetic
            audio waveform (sine) for development and testing instead of
            attempting to read from an I2S peripheral. This is useful
            when no physical I2S source is attached. Note: enabling this
            disables the normal I2S read path at build-time.

    menu "Audio Configuration Defaults"
        config AUDIO_DEFAULT_SAMPLE_RATE
            int "Default Audio Sample Rate (Hz)"
            default 48000
            range 8000 96000
            help
                Default sample rate for audio processing at boot.
                Common values: 48000 (professional/streaming), 44100 (CD quality),
                32000, 22050, 16000, 8000.
                Can be overridden at runtime via NVS or future commands.

        config AUDIO_DEFAULT_VOLUME
            int "Default Audio Volume (0-100)"
            default 80
            range 0 100
            help
                Default volume level for audio output at boot (0-100).
                0 = muted, 100 = maximum volume.
                Can be adjusted at runtime via VOLUME command.

        config AUDIO_DEFAULT_BIT_DEPTH
            int "Default Audio Bit Depth"
            default 16
            help
                Default bit depth for audio samples.
                Common values: 16 (standard), 24 (high quality), 32 (professional).
                Must match I2S source capabilities.

        config AUDIO_AUTOSTART_DEFAULT
            bool "Enable Audio Autostart by Default"
            default y
            help
                When enabled, audio processor initializes and starts automatically
                at boot. When disabled, audio init is deferred until explicitly
                requested via command or application logic.
                Runtime setting stored in NVS takes precedence if configured.

        config AUDIO_RB_CAPACITY_KB
            int "Ring Buffer Capacity (KB)"
            default 32
            range 8 256
            help
                Audio ring buffer capacity in kilobytes.
                Larger buffers provide more headroom against underruns but use more memory.
                32KB = 167ms @ 48kHz stereo 16-bit (192KB/s)
                128KB = 667ms buffer (requires PSRAM for this size)
                Recommended: 32KB (DRAM) or 128KB (PSRAM)

        config AUDIO_RB_USE_PSRAM
            bool "Use PSRAM for Ring Buffer"
            default n
            depends on SPIRAM
            help
                When enabled, allocate ring buffer in PSRAM instead of DRAM.
                Recommended for large buffers (>64KB) to conserve DRAM.
                Requires PSRAM to be enabled and available.
                Note: Ring buffer structure itself is always in DRAM (small overhead).
    endmenu

    menu "Bluetooth Logging Configuration"
        config BT_VERBOSE_AUDIO_LOGGING
            bool "Enable Verbose Audio Logging (Development Only)"
            default n
            help
                WARNING: Enabling this option can cause audio glitches!
                
                When enabled, logs detailed audio data callback events including:
                - Audio processor read errors
                - Buffer underruns with byte counts
                - Underrun rate statistics
                
                This is a BLOCKING I/O operation that can exceed the 2.9ms 
                audio frame deadline at 44.1kHz, causing audio glitches.
                
                Only enable for development/debugging. NEVER enable in production.
                
                Recommended: Keep DISABLED (default) for normal operation.
    endmenu
endmenu
