#!/bin/bash
#
# Git pre-push hook - Runs standalone host tests before pushing
#
# This ensures that commits match GitHub Actions CI requirements.
# The standalone build catches missing mocks and linker errors that
# incremental builds might miss.
#
# To install this hook:
#   cp tools/hooks/pre-push .git/hooks/pre-push
#   chmod +x .git/hooks/pre-push
#
# To bypass temporarily (use sparingly):
#   git push --no-verify
#

set -e

echo ""
echo "🔍 Pre-push check: Running standalone host tests (CI parity)..."
echo ""

# Change to repository root
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Check if we're in the right place
if [ ! -f "esp_bt_audio_source/test/host_test/CMakeLists.txt" ]; then
    echo "⚠️  Warning: Cannot find host test CMakeLists.txt"
    echo "Skipping pre-push tests (not in expected repository structure)"
    exit 0
fi

# Run standalone tests using Makefile
cd esp_bt_audio_source/test/host_test

if make test; then
    echo ""
    echo "✅ Pre-push check PASSED"
    echo "   Standalone host tests match CI requirements"
    echo ""
    exit 0
else
    echo ""
    echo "❌ Pre-push check FAILED"
    echo ""
    echo "Standalone host tests failed. This push would break GitHub Actions CI."
    echo ""
    echo "Common causes:"
    echo "  - Missing mock implementations in test/host_test/mocks/"
    echo "  - New functions in components/ not mocked for host tests"
    echo "  - Linker errors due to missing symbols"
    echo ""
    echo "To fix:"
    echo "  1. Review the test failures above"
    echo "  2. Add missing mocks or fix linker errors"
    echo "  3. Verify with: cd esp_bt_audio_source/test/host_test && make test"
    echo ""
    echo "To bypass this check (not recommended):"
    echo "  git push --no-verify"
    echo ""
    exit 1
fi
