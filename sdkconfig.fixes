CONFIG_BT_ENABLED=y
CONFIG_BT_BLUEDROID_ENABLED=y

# Change mode from BLE-only to Classic BT
CONFIG_BTDM_CTRL_MODE_BLE_ONLY=n
CONFIG_BTDM_CTRL_MODE_BR_EDR_ONLY=y 
CONFIG_BTDM_CTRL_MODE_BTDM=n

# Enable Classic BT features needed for audio
CONFIG_BT_CLASSIC_ENABLED=y
CONFIG_BT_A2DP_ENABLE=y
CONFIG_BT_SPP_ENABLED=y

# Disable BLE since we're using Classic BT only
CONFIG_BT_BLE_ENABLED=n
CONFIG_BT_NIMBLE_ENABLED=n

# Set appropriate connection limits
CONFIG_BTDM_CTRL_BR_EDR_MAX_ACL_CONN=2
CONFIG_BTDM_CTRL_BR_EDR_MAX_SYNC_CONN=1
CONFIG_BT_ACL_CONNECTIONS=2

# Enable security features for pairing
CONFIG_BT_SSP_ENABLED=y
CONFIG_BT_SMP_ENABLE=y

# Profile settings
CONFIG_BT_A2DP_SINK_TASK_STACK_SIZE=2048
CONFIG_BT_A2DP_SOURCE_TASK_STACK_SIZE=2048

# Add proper backward compatibility for legacy audio devices
CONFIG_FREERTOS_ENABLE_BACKWARD_COMPATIBILITY=y

# Ensure Bluetooth has enough resources
CONFIG_BTDM_RESERVE_DRAM=0xdb5c
