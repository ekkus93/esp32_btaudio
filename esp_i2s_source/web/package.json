{
  "name": "esp-i2s-source-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Web UI for the ESP32-S3 audio source. Built off-device; the gzipped single-file bundle is embedded into the firmware (see scripts/embed_web.mjs).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node scripts/embed_web.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-singlefile": "^2.1.0"
  }
}
