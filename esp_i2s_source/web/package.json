{
  "name": "esp-i2s-source-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Web UI for the ESP32-S3 audio source. Built off-device; the gzipped single-file bundle is embedded into the firmware (see scripts/embed_web.mjs).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node scripts/embed_web.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:device": "LIVE_DEVICE=1 playwright test"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^28.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-singlefile": "^2.1.0",
    "vitest": "^4.1.10"
  }
}
